    {
      "name": "04581833",
      "displayName": "Sales Goal",
      "queryLines": [
        "SELECT\r\n",
        "\r\n",
        "sum(total_price) AS Total_Sales, 3000000 AS Sales_Goal\r\n",
        "\r\n",
        "FROM\r\n",
        "\r\n",
        "databricks_simulated_retail_customer_data.v01.sales;"
      ]
    },
    {
      "name": "0c48df71",
      "displayName": "Sales Over Three Months",
      "queryLines": [
        "SELECT customer_name, \r\n",
        "       total_price AS Total_Sales, \r\n",
        "       date_format(order_date, \"MM\") AS Month, \r\n",
        "       product_category \r\n",
        "FROM databricks_simulated_retail_customer_data.v01.sales \r\n",
        "WHERE order_date >= to_date('2019-08-01')\r\n",
        "AND order_date <=  to_date('2019-10-31');"
      ]
    },
    {
      "name": "d9b88a66",
      "displayName": "sales",
